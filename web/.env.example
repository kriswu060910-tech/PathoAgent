# ===== 使用说明 =====
# 1. 复制本文件为 .env：cp .env.example .env
# 2. 填写 VITE_API_KEY（必须），否则 Agent 将降级为简单聊天模式，无法使用任何工具
# 3. 根据需要配置搜索、视觉、后端服务等可选变量
# 4. Python 解释器路径（可选，launcher 和 vite 开发插件使用）
#    默认使用 D:\miniconda3\envs\patho\python.exe，可通过此变量覆盖
#    PYTHON_PATH=D:\miniconda3\envs\patho\python.exe

# ===== LLM 配置（必须）=====
# 不配置此项，Agent 将无法进行工具调用，仅支持简单聊天
VITE_API_KEY=your-deepseek-api-key
VITE_API_BASE_URL=https://api.deepseek.com
VITE_API_MODEL=deepseek-chat

# 联网搜索配置（可选）
# 支持的供应商：duckduckgo / tavily / serper / mock
# - duckduckgo: 免费，无需 API Key（开发环境已配置 Vite 代理）
# - tavily: https://tavily.com （推荐，专为 AI Agent 设计）
# - serper: https://serper.dev （Google 搜索结果）
# - mock: 本地演示模式，不消耗 API 额度
VITE_SEARCH_PROVIDER=duckduckgo
VITE_SEARCH_API_KEY=your-search-api-key
VITE_SEARCH_MAX_RESULTS=5

# 视觉识别配置（可选）
# 使用 OpenAI 兼容的多模态 API，支持：
# - DashScope（阿里云）: https://dashscope.aliyuncs.com/compatible-mode/v1 + qwen-vl-max
# - OpenAI: https://api.openai.com/v1 + gpt-4o
# - SiliconFlow: https://api.siliconflow.cn/v1 + Qwen/Qwen2-VL-72B-Instruct
# - 其他兼容接口
#
# 开发环境通过 /api/vision 代理访问（解决 CORS），默认代理 DashScope
# 如需切换提供商，修改 VITE_VISION_PROXY_TARGET 后重启 dev server
# 设置界面中 API Base URL 填 /api/vision 即可
VITE_VISION_PROXY_TARGET=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_VISION_BASE_URL=
VITE_VISION_API_KEY=
VITE_VISION_MODEL=gpt-4o

# CORS 代理（仅在生产环境或浏览器直接访问 duckduckgo 时需要）
# 例如：https://corsproxy.io/?
VITE_CORS_PROXY=

# ===== 本地后端服务地址（可选，通常无需修改）=====
# 开发模式自动使用 Vite 代理路径（/api/patho 等）
# 生产模式（Tauri）自动使用直连地址（http://localhost:8001 等）
# 仅当后端运行在非默认端口时才需要取消注释并修改
# VITE_PATHO_API_URL=http://localhost:8001
# VITE_CELLPOSE_API_URL=http://localhost:8002
# VITE_LAUNCHER_API_URL=http://localhost:8099
