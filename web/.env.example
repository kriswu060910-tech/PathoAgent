# Python 解释器路径（可选，launcher.py 和 vite 开发插件使用）
# 默认使用 D:\miniconda3\envs\patho\python.exe，可通过此变量覆盖
# PYTHON_PATH=D:\miniconda3\envs\patho\python.exe

VITE_API_KEY=your-deepseek-api-key
VITE_API_BASE_URL=https://api.deepseek.com
VITE_API_MODEL=deepseek-chat

# 联网搜索配置（可选）
# 支持的供应商：duckduckgo / tavily / serper / mock
# - duckduckgo: 免费，无需 API Key（开发环境已配置 Vite 代理）
# - tavily: https://tavily.com （推荐，专为 AI Agent 设计）
# - serper: https://serper.dev （Google 搜索结果）
# - mock: 本地演示模式，不消耗 API 额度
VITE_SEARCH_PROVIDER=duckduckgo
VITE_SEARCH_API_KEY=your-search-api-key
VITE_SEARCH_MAX_RESULTS=5

# 视觉识别配置（可选）
# 使用 OpenAI 兼容的多模态 API，支持：
# - OpenAI: https://api.openai.com/v1 + gpt-4o
# - SiliconFlow: https://api.siliconflow.cn/v1 + Qwen/Qwen2-VL-72B-Instruct
# - 其他兼容接口
VITE_VISION_BASE_URL=
VITE_VISION_API_KEY=
VITE_VISION_MODEL=gpt-4o

# CORS 代理（仅在生产环境或浏览器直接访问 duckduckgo 时需要）
# 例如：https://corsproxy.io/?
VITE_CORS_PROXY=
