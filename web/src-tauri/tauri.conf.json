{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "PathoAgent",
  "version": "0.1.0",
  "identifier": "com.cookie.patho-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PathoAgent - 病理图像分析",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://api.deepseek.com https://dashscope.aliyuncs.com https://api.siliconflow.cn https://api.openai.com https://api.allorigins.win https://api.tavily.com https://google.serper.dev; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../../launcher",
      "../../auth",
      "../../cellpose",
      "../../Patho-R1",
      "../../shared",
      "../../shared_image_utils.py",
      "../../shared_logger.py",
      "../../.env.example"
    ]
  }
}
